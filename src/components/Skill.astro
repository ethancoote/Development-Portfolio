---
const { text, src, alt, addClasses = "" } = Astro.props;
---

<div class:list={["flex gap-3 bg-neutral-800 w-fit pl-2 pr-3 py-2 rounded-md text-neutral-200 shrink-0", addClasses]}>
    <img src={src} alt={alt} class=" skillImg h-[24px] rounded-sm aspect-1/1">
    <p class="skillText">{text}</p>
</div>