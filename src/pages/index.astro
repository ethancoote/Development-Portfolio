---
import Header from '../components/Header.astro';
import Icon from '../components/buttons/Icon.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import ContactForm from '../components/ContactForm.astro';
import Skill from '../components/Skill.astro';
import Footer from '../components/Footer.astro';
import Experience from '../components/Experience.astro';
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Portfolio | Ethan Coote</title>
	</head>
	<body class="flex flex-col bg-neutral-900 items-center">
		<Header />
		<!-- hero -->
		<main class="flex pt-40 sm:pt-48 pb-8 items-center px-5 sm:px-9 w-full max-w-[1400px] justify-center text-center" id="hero">
			<div class="flex flex-col pb-12 gap-6 items-center">
				<div class="flex flex-col gap-6 items-center justify-center">
					<img src="./images/profile-480.webp" alt="ethan coote profile" class="aspect-1/1 rounded-full w-[72px] border border-neutral-600">
					<div class="flex flex-col">
						<h1 class="text-4xl text-neutral-100 font-regular sm:text-4xl">Ethan Coote</h1>
						<p class="text-[20px] pl-1 font-regular text-neutral-400">Web Developer</p>
					</div>
					
				</div>
				
				<p class="text-[20px] font-regular text-neutral-400 max-w-[600px] ">I’m a web developer living in Guelph ON, Canada. I specialize in UI/UX and front-end development.</p>
				<div class="flex gap-4">
					<Icon 
						href="https://github.com/ethancoote" 
						src="./images/icons/github-icon.svg"
						alt="github icon"
					/>
					<Icon 
						href="mailto:ecoote456@gmail.com" 
						src="./images/icons/mail-icon.svg"
						alt="mailto icon"
					/>
				</div>
			</div>
		</main>

		<!-- projects -->
		<section class="flex flex-col w-full h-fit px-2 py-6 sm:p-6 max-w-[1400px] justify-center gap-4 scroll-mt-16 mb-16" id="projects">
			<div class="flex flex-col gap-6 px-3">
				<h2 class="text-neutral-100 text-4xl sm:text-5xl">Recent <span class="text-neutral-400">Projects.</span></h2>
				<div class="h-[1px] w-full bg-neutral-700"></div>
			</div>
			<ProjectGrid />
		</section>

		<!-- experience -->
		<section class="flex flex-col w-full h-fit px-5 py-6 sm:px-9 max-w-[1400px] justify-center gap-4 scroll-mt-16 mb-16" id="experience">
			<div class="flex flex-col gap-6">
				<h3 class="text-neutral-100 text-4xl sm:text-5xl">Experience <span class="text-neutral-400">& Education.</span></h3>
				<div class="h-[1px] w-full bg-neutral-700"></div>
			</div>
			<div class="flex flex-col w-full h-fit text-neutral-400 border border-1 border-neutral-800 text-md sm:text-lg p-4 sm:p-6 rounded-lg gap-1">
				<p class="text-neutral-100 text-2xl">Bachelor of Computing</p>
				<p>Major in Computer Science | Minor in Business &nbsp; • &nbsp; 2019 - 2024</p>
				<p class="text-neutral-300 text-xl">University of Guelph</p>
			</div>
			<Experience role="Web Designer & Developer" company="Independent Contractor" years="2025 - present" />
			<Experience role="Test Engineering Intern" company="Semtech" years="2021 - 2023" />
			

		</section>

		<!-- stack -->
		<section class="flex flex-col w-full h-fit px-5 py-6 sm:px-9 max-w-[1400px] justify-center gap-4 scroll-mt-16 mb-16" id="stack">
			<div class="flex flex-col gap-6">
				<h3 class="text-neutral-100 text-4xl sm:text-5xl">Tech <span class="text-neutral-400">Stack.</span></h3>
				<div class="h-[1px] w-full bg-neutral-700"></div>
				<div class="flex gap-8">
					<div class="flex flex-col gap-2 w-full h-fit">
						<p class="text-neutral-500 text-xl">Languages</p>
						<div class="flex flex-wrap gap-2 mb-2">
							<Skill text="JavaScript" src="./images/icons/js-icon.svg" alt="javascript icon" addClasses="skillHover hover:cursor-default" />
							<Skill text="TypeScript" src="./images/icons/ts-icon.svg" alt="typescript icon" addClasses="skillHover hover:cursor-default" />
							<Skill text="HTML5" src="./images/icons/html-icon.svg" alt="html5 icon" addClasses="skillHover hover:cursor-default" />
							<Skill text="CSS" src="./images/icons/css-icon.svg" alt="css icon" addClasses="skillHover hover:cursor-default" /> 
						</div>
						<p class="text-neutral-500 text-xl">Front-End</p>
						<div class="flex flex-wrap gap-2 mb-2">
							<Skill text="React.js" src="./images/icons/react-icon.svg" alt="react.js icon" addClasses="skillHover hover:cursor-default"  />
							<Skill text="Astro" src="./images/icons/astro-icon.svg" alt="astro icon" addClasses="skillHover hover:cursor-default" />
							<Skill text="TailwindCSS" src="./images/icons/tailwindcss-icon.svg" alt="tailwindcss icon" addClasses="skillHover hover:cursor-default" />
						</div>
						<p class="text-neutral-500 text-xl">Back-End</p>
						<div class="flex flex-wrap gap-2 mb-2">
							<Skill text="Node.js" src="./images/icons/node-icon.svg" alt="node.js icon" addClasses="skillHover hover:cursor-default" />
							<Skill text="Express.js" src="./images/icons/express-icon.svg" alt="express.js icon" addClasses="skillHover hover:cursor-default" />
							<Skill text="Next.js" src="./images/icons/next-icon.svg" alt="next.js icon" addClasses="skillHover hover:cursor-default" />
							<Skill text="Firebase" src="./images/icons/firebase-icon.svg" alt="firebase icon" addClasses="skillHover hover:cursor-default" />
							<Skill text="MySQL" src="./images/icons/mysql-icon.svg" alt="mysql icon" addClasses="skillHover hover:cursor-default" />
						</div>
						<p class="text-neutral-500 text-xl">SEO</p>
						<div class="flex flex-wrap gap-2 mb-2">
							<Skill text="Screaming Frog" src="./images/icons/sf-icon.svg" alt="screaming frog icon" addClasses="skillHover hover:cursor-default" />
							<Skill text="Ahrefs" src="./images/icons/ahrefs-icon.svg" alt="ahrefs icon" addClasses="skillHover hover:cursor-default" />
						</div>
						<p class="text-neutral-500 text-xl">Hosting</p>
						<div class="flex flex-wrap gap-2 mb-2">
							<Skill text="Firebase Hosting" src="./images/icons/firebase-icon.svg" alt="firebase icon" addClasses="skillHover hover:cursor-default" />
							<Skill text="Netlify" src="./images/icons/netlify-icon.svg" alt="netlify icon" addClasses="skillHover hover:cursor-default" />
							<Skill text="Github Pages" src="./images/icons/github-icon.svg" alt="github icon" addClasses="skillHover hover:cursor-default" />
						</div>
						<p class="text-neutral-500 text-xl">Other</p>
						<div class="flex flex-wrap gap-2 mb-2">
							<Skill text="Framer" src="./images/icons/framer-icon.svg" alt="framer icon" addClasses="skillHover hover:cursor-default" />
							<Skill text="Github Actions" src="./images/icons/github-icon.svg" alt="github icon" addClasses="skillHover hover:cursor-default" />
							<Skill text="Git" src="./images/icons/git-icon.svg" alt="git icon" addClasses="skillHover hover:cursor-default" />
							<Skill text="Figma" src="./images/icons/figma-icon.svg" alt="figma icon" addClasses="skillHover hover:cursor-default" />
							<Skill text="Docker" src="./images/icons/docker-icon.svg" alt="docker icon" addClasses="skillHover hover:cursor-default" />
						</div>
						
					</div>
					<div class=" hidden md:flex items-center justify-center w-full flex-col gap-2 ">
						<div class="w-fit h-fit border border-neutral-800 rounded-lg overflow-clip">
							<div class=" w-[256px] h-[256px] flex items-center justify-center bg-neutral-800">
								<img src="./images/icons/js-icon.svg" alt="javascript icon" class="h-[156px] rounded-lg" id="skill-img">
							</div>
							<p class="text-2xl text-neutral-300 m-2 text-center mb-3" id="skill-text">Javascript</p>
						</div>
							
					</div>
				</div>
				
			</div>
		</section>

		<!-- contact -->
		<section class="flex flex-col w-full h-fit px-5 py-6 sm:px-9 max-w-[1400px] justify-center gap-4 scroll-mt-16 mb-16" id="contact">
			<div class="flex flex-col gap-6">
				<h3 class="text-neutral-100 text-4xl sm:text-5xl">Get in <span class="text-neutral-400">Touch.</span></h3>
				<div class="h-[1px] w-full bg-neutral-700"></div>
				<div class="flex gap-8 w-full flex-col-reverse md:flex-row">
					<div class="flex flex-col w-full gap-2">
						<ContactForm />
					</div>
					<div class="flex flex-col w-full gap-4 text-xl text-neutral-300 justify-center">
						<div class="flex gap-6 mb-2 items-center">
							<img src="./images/profile-480.webp" alt="ethan coote profile" class="aspect-1/1 rounded-full w-[72px] border border-neutral-600">
							<div class="flex flex-col">
								<h1 class="text-3xl text-neutral-100 font-regular">Ethan Coote</h1>
								<p class="font-regular text-neutral-400">Web Developer</p>
							</div>
							
						</div>
						
						<p>Feel free to send me a message anytime. You can also email me directly at the address below.</p>
						<div class="flex flex-col">
							<p class="text-neutral-500">Email</p>
							<p>ecoote456@gmail.com</p>
						</div>
						<div class="flex flex-col">
							<p class="text-neutral-500">Github</p>
							<p>https://github.com/ethancoote</p>
						</div>
						<div class="flex gap-4 mt-2">
							<Icon 
								href="https://github.com/ethancoote" 
								src="./images/icons/github-icon.svg"
								alt="github icon"
							/>
							<Icon 
								href="mailto:ecoote456@gmail.com" 
								src="./images/icons/mail-icon.svg"
								alt="mailto icon"
							/>
						</div>
					</div>
				</div>
				
			</div>
		</section>

		<Footer />
		<script src="../scripts/skillHover.ts"></script>
	</body>
</html>
